# NAS 系统类型 (synology/qnap/fnos/generic)
# 如不指定，系统将自动探测
NAS_SYSTEM=generic

# 允许访问的根目录（逗号分隔）
# 示例：ALLOWED_ROOTS=/volume1,/volume2,/share
# 安全提示：请根据实际需求限制访问范围，不要使用 /
ALLOWED_ROOTS=/

# 监听地址
HOST=0.0.0.0

# 监听端口
PORT=8000

# 插件目录路径（可选）
# PLUGIN_DIR=/app/plugins

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
